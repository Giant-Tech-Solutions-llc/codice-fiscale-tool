run = "php -S 0.0.0.0:8000 -t ."

entrypoint = "index.php"
modules = ["nodejs-20", "python-3.11"]

[nix]
channel = "stable-22_11"

[deployment]
deploymentTarget = "autoscale"
run = ["node", "server.js"]

[[ports]]
localPort = 5000
externalPort = 80

[agent]
expertMode = true
integrations = ["github:1.0.0"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node server.js"
waitForPort = 5000
