              <td>Fronte, sotto il nome</td>
            </tr>
            <tr>
              <td>Tesserino verde</td>
              <td>Centro del documento</td>
            </tr>
            <tr>
              <td>Buste paga</td>
              <td>Intestazione</td>
            </tr>
            <tr>
              <td>Dichiarazione dei redditi (730, Unico)</td>
