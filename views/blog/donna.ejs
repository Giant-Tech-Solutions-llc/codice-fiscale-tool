          <thead>
            <tr>
              <th>Passo</th>
              <th>Dato</th>
              <th>Regola Applicata</th>
              <th>Risultato</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>1</td>
              <td>Cognome: ROSSI</td>
              <td>Consonanti R, S, S</td>
              <td class="mono">RSS</td>
            </tr>
            <tr>
              <td>2</td>
              <td>Nome: MARIA</td>
              <td>Consonanti M, R + vocale A</td>
              <td class="mono">MRA</td>
            </tr>
            <tr>
              <td>3</td>
              <td>Anno: 1990</td>
              <td>Ultime 2 cifre</td>
              <td class="mono">90</td>
            </tr>
            <tr>
              <td>4</td>
              <td>Mese: Febbraio</td>
              <td>Lettera corrispondente</td>
              <td class="mono">B</td>
            </tr>
            <tr>
              <td>5</td>
              <td>Giorno: 18 + Donna</td>
              <td>18 + 40</td>
              <td class="mono">58</td>
            </tr>
            <tr>
              <td>6</td>
              <td>Comune: Roma</td>
