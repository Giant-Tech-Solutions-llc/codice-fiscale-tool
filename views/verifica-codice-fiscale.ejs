<section class="cf-page">
  <div class="cf-container" style="max-width:600px">
    <div class="cf-card">
      <div class="cf-card__header">
        <h1 class="cf-card__title">Verifica Codice Fiscale</h1>
        <p class="cf-card__subtitle">Inserisci un Codice Fiscale per verificarne la validità e visualizzare i dettagli</p>
      </div>

      <div class="cf-card__body">
        <form id="verifica-form" method="POST" novalidate>
          <div class="cf-field">
            <label class="cf-label" for="codice_fiscale">Codice Fiscale</label>
            <input class="cf-input" type="text" id="codice_fiscale" name="codice_fiscale" placeholder="Es. RSSMRA85C15H501R" required autocomplete="off" maxlength="16" style="text-transform:uppercase;font-family:'Courier New',monospace;letter-spacing:.1em;font-size:1.1rem">
          </div>
          <button type="submit" class="cf-btn" id="verifica-btn">Verifica Codice Fiscale</button>
        </form>

        <div id="verifica-result" class="verifica-result" style="display:none">

          <div id="verdict-badge" class="verdict-badge">
            <div class="verdict-icon" id="verdict-icon"></div>
            <div class="verdict-text" id="verdict-text"></div>
            <div class="verdict-sub" id="verdict-sub"></div>
          </div>

          <div id="verifica-code-display" style="text-align:center;margin-bottom:1.5rem">
            <span style="display:block;font-size:.8125rem;font-weight:600;color:var(--primary);text-transform:uppercase;letter-spacing:.05em;margin-bottom:.5rem">Codice Fiscale</span>
            <output id="verifica-cf-output" style="display:block;font-size:1.75rem;font-weight:700;letter-spacing:.15em;color:var(--text);font-family:'Courier New',monospace;word-break:break-all;padding:.5rem 0"></output>
            <button type="button" class="cf-copy" id="verifica-copy-btn" aria-label="Copia Codice Fiscale negli appunti" style="margin-top:.75rem">
              <svg class="cf-copy__icon" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M8 2a1 1 0 000 2h2a1 1 0 100-2H8z"/><path d="M3 5a2 2 0 012-2 3 3 0 003 3h2a3 3 0 003-3 2 2 0 012 2v6h-4.586l1.293-1.293a1 1 0 00-1.414-1.414l-3 3a1 1 0 000 1.414l3 3a1 1 0 001.414-1.414L10.414 13H15v3a2 2 0 01-2 2H5a2 2 0 01-2-2V5z"/></svg>
              <span id="verifica-copy-text">Copia</span>
            </button>
          </div>

          <div class="check-list" id="check-list">
            <h3>Dettaglio Verifiche</h3>
            <ul class="check-items" id="check-items"></ul>
          </div>

          <div class="quick-extract" id="quick-extract" style="display:none">
            <h3>Dati Estratti</h3>
            <div class="quick-extract__grid" id="qe-grid"></div>
          </div>

        </div>
      </div>
    </div>
  </div>
</section>

<style>
.cf-page {
  padding: 32px 0 48px;
  min-height: calc(100vh - 200px);
  display: flex;
  align-items: flex-start;
  justify-content: center;
}

.cf-container {
  width: 100%;
  max-width: 600px;
  padding: 0 16px;
}

.cf-card {
  background: var(--white);
  border-radius: 16px;
  box-shadow: 0 4px 24px rgba(0, 0, 0, .08), 0 1px 3px rgba(0, 0, 0, .04);
  overflow: hidden;
}

.cf-card__header {
  background: linear-gradient(135deg, #006B35, #008C45);
  padding: 32px 24px;
  text-align: center;
  color: var(--white);
}

.cf-card__title {
  font-size: 1.5rem;
  font-weight: 700;
  letter-spacing: -.02em;
  margin-bottom: 8px;
}

.cf-card__subtitle {
  font-size: .875rem;
  opacity: .85;
  line-height: 1.5;
}

.cf-card__body {
  padding: 24px;
}

.cf-field {
  margin-bottom: 24px;
  border: none;
  padding: 0;
}

.cf-label {
  display: block;
  font-size: .8125rem;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 8px;
  letter-spacing: .01em;
}

.cf-input {
  display: block;
  width: 100%;
  height: 48px;
  padding: 0 16px;
  border: 2px solid var(--border);
  border-radius: 8px;
  font-size: 1rem;
  font-family: var(--font);
  color: var(--text);
  background: var(--white);
  transition: border-color .2s, box-shadow .2s;
  -webkit-appearance: none;
}

.cf-input::placeholder {
  color: #9ca3af;
}

.cf-input:focus {
  outline: none;
  border-color: var(--primary);
  box-shadow: 0 0 0 3px var(--primary-light);
}

.cf-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 48px;
  background: var(--primary);
  color: var(--white);
  border: none;
  border-radius: 8px;
  font-size: 1rem;
  font-weight: 600;
  font-family: var(--font);
  cursor: pointer;
  transition: background .2s, transform .1s;
  margin-top: 8px;
}

.cf-btn:hover {
  background: var(--primary-dark);
}

.cf-btn:active {
  transform: scale(.98);
}

.cf-btn:focus-visible {
  outline: 2px solid var(--primary);
  outline-offset: 2px;
}

.cf-copy {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 8px 20px;
  background: var(--primary);
  color: var(--white);
  border: none;
  border-radius: 6px;
  font-size: .875rem;
  font-weight: 600;
  font-family: var(--font);
  cursor: pointer;
  transition: background .2s;
}

.cf-copy:hover {
  background: var(--primary-dark);
}

.cf-copy--done {
  background: var(--text);
}

.cf-copy__icon {
  width: 16px;
  height: 16px;
}

@keyframes cfFadeIn {
  from { opacity: 0; transform: translateY(8px); }
  to   { opacity: 1; transform: translateY(0); }
}

.verifica-result {
  margin-top: 2rem;
  padding-top: 2rem;
  border-top: 1px solid var(--border, #e5e7eb);
  animation: cfFadeIn .4s ease;
}

.verdict-badge {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.5rem;
  padding: 2rem 1.5rem;
  border-radius: 16px;
  text-align: center;
  margin-bottom: 2rem;
  transition: box-shadow 0.2s ease;
}

.verdict-valid {
  background: linear-gradient(135deg, #d1fae5, #a7f3d0);
  border: 2px solid #10B981;
}

.verdict-invalid {
  background: linear-gradient(135deg, #fee2e2, #fecaca);
  border: 2px solid #EF4444;
}

.verdict-icon {
  width: 3.5rem;
  height: 3.5rem;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.8rem;
  font-weight: 900;
  line-height: 1;
}

.verdict-valid .verdict-icon {
  background: #10B981;
  color: #fff;
}

.verdict-invalid .verdict-icon {
  background: #EF4444;
  color: #fff;
}

.verdict-text {
  font-size: 1.4rem;
  font-weight: 800;
  letter-spacing: 0.04em;
}

.verdict-valid .verdict-text   { color: #065F46; }
.verdict-invalid .verdict-text { color: #991B1B; }

.verdict-sub {
  font-size: 0.9rem;
  max-width: 480px;
  line-height: 1.5;
}

.verdict-valid .verdict-sub   { color: #065F46; }
.verdict-invalid .verdict-sub { color: #7F1D1D; }

.check-list {
  margin-bottom: 1.5rem;
}

.check-list h3 {
  font-size: 1rem;
  font-weight: 600;
  margin-bottom: 0.75rem;
  color: var(--text, #1a1a1a);
}

.check-items {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.check-item {
  display: grid;
  grid-template-columns: 1.6rem 1fr;
  grid-template-rows: auto auto;
  column-gap: 0.75rem;
  padding: 0.75rem 1rem;
  border-radius: 8px;
  border: 1px solid transparent;
}

.check-pass {
  background: #f0fdf4;
  border-color: #bbf7d0;
}

.check-fail {
  background: #fff1f2;
  border-color: #fecdd3;
}

.check-icon {
  grid-row: 1 / 3;
  font-size: 1rem;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.check-pass .check-icon { color: #10B981; }
.check-fail .check-icon { color: #EF4444; }

.check-label {
  font-weight: 600;
  font-size: 0.875rem;
  color: var(--text, #1a1a1a);
}

.check-detail {
  font-size: 0.8rem;
  color: var(--text-light, #666);
  margin-top: 0.15rem;
}

.quick-extract {
  background: var(--primary-light, #f8f9fa);
  border: 1px solid var(--border, #e5e7eb);
  border-radius: 12px;
  padding: 1.25rem 1.5rem;
  margin-bottom: 1.5rem;
}

.quick-extract h3 {
  font-size: 0.9rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--text-light, #888);
  margin-bottom: 1rem;
}

.quick-extract__grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
  gap: 0.75rem;
}

.qe-item {
  display: flex;
  flex-direction: column;
  gap: 0.2rem;
}

.qe-label {
  font-size: 0.75rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: var(--text-light, #888);
}

.qe-value {
  font-size: 1rem;
  font-weight: 700;
  color: var(--primary, #1E7F4F);
}

@media (max-width: 600px) {
  .verdict-text { font-size: 1.1rem; }
  .verdict-badge { padding: 1.5rem 1rem; }

  .check-item {
    grid-template-columns: 1.4rem 1fr;
    padding: 0.6rem 0.75rem;
  }

  .quick-extract__grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (min-width: 640px) {
  .cf-page {
    padding: 48px 0 64px;
  }
  .cf-card__header {
    padding: 40px 32px;
  }
  .cf-card__title {
    font-size: 1.75rem;
  }
  .cf-card__body {
    padding: 32px;
  }
}
</style>

<script>
(function () {
  var form = document.getElementById('verifica-form');
  var input = document.getElementById('codice_fiscale');
  var resultSection = document.getElementById('verifica-result');
  var verdictBadge = document.getElementById('verdict-badge');
  var verdictIcon = document.getElementById('verdict-icon');
  var verdictText = document.getElementById('verdict-text');
  var verdictSub = document.getElementById('verdict-sub');
  var checkItems = document.getElementById('check-items');
  var quickExtract = document.getElementById('quick-extract');
  var qeGrid = document.getElementById('qe-grid');
  var cfOutput = document.getElementById('verifica-cf-output');
  var codeDisplay = document.getElementById('verifica-code-display');

  if (form) {
    form.addEventListener('submit', function (e) {
      e.preventDefault();
      var cf = input.value.trim().toUpperCase();
      if (!cf) return;

      var btn = document.getElementById('verifica-btn');
      btn.disabled = true;
      btn.textContent = 'Verifica in corso...';

      fetch('/api/verifica', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ codice_fiscale: cf })
      })
      .then(function (r) { return r.json(); })
      .then(function (data) {
        btn.disabled = false;
        btn.textContent = 'Verifica Codice Fiscale';
        renderResult(data);
      })
      .catch(function () {
        btn.disabled = false;
        btn.textContent = 'Verifica Codice Fiscale';
        alert('Errore durante la verifica. Riprova.');
      });
    });
  }

  function renderResult(data) {
    resultSection.style.display = 'block';
    resultSection.style.animation = 'none';
    resultSection.offsetHeight;
    resultSection.style.animation = 'cfFadeIn .4s ease';

    verdictBadge.className = 'verdict-badge ' + (data.valid ? 'verdict-valid' : 'verdict-invalid');
    verdictIcon.textContent = data.valid ? '✓' : '✗';
    verdictText.textContent = data.valid ? 'Codice Fiscale Valido' : 'Codice Fiscale Non Valido';
    verdictSub.textContent = data.valid
      ? 'Il codice fiscale inserito ha superato tutti i controlli di validità.'
      : 'Il codice fiscale inserito non ha superato tutti i controlli.';

    cfOutput.textContent = data.codiceFiscale || input.value.trim().toUpperCase();
    codeDisplay.style.display = 'block';

    var checks = data.checks || [];
    checkItems.innerHTML = '';
    checks.forEach(function (check) {
      var li = document.createElement('li');
      li.className = 'check-item ' + (check.pass ? 'check-pass' : 'check-fail');
      li.innerHTML =
        '<span class="check-icon">' + (check.pass ? '✓' : '✗') + '</span>' +
        '<span class="check-label">' + escapeHtml(check.label) + '</span>' +
        '<span class="check-detail">' + escapeHtml(check.detail) + '</span>';
      checkItems.appendChild(li);
    });

    if (data.valid && data.extract) {
      quickExtract.style.display = 'block';
      qeGrid.innerHTML = '';
      var fields = [
        { label: 'Sesso', value: data.extract.genderLabel },
        { label: 'Data di Nascita', value: data.extract.dateStr },
        { label: 'Comune', value: data.extract.municipalityName || data.extract.municipalityCode },
        { label: 'Cognome (segmento)', value: data.extract.surnameSegment },
        { label: 'Nome (segmento)', value: data.extract.nameSegment },
        { label: 'Carattere Controllo', value: data.extract.checkChar }
      ];
      fields.forEach(function (f) {
        if (f.value) {
          var div = document.createElement('div');
          div.className = 'qe-item';
          div.innerHTML = '<span class="qe-label">' + escapeHtml(f.label) + '</span><span class="qe-value">' + escapeHtml(f.value) + '</span>';
          qeGrid.appendChild(div);
        }
      });
    } else {
      quickExtract.style.display = 'none';
    }
  }

  function escapeHtml(str) {
    if (!str) return '';
    return String(str).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  var copyBtn = document.getElementById('verifica-copy-btn');
  if (copyBtn) {
    copyBtn.addEventListener('click', function () {
      var code = document.getElementById('verifica-cf-output');
      if (!code) return;
      var text = code.textContent.trim();
      if (!text) return;

      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(text).then(onCopied).catch(fallbackCopy);
      } else {
        fallbackCopy();
      }

      function fallbackCopy() {
        var ta = document.createElement('textarea');
        ta.value = text;
        ta.style.position = 'fixed';
        ta.style.opacity = '0';
        document.body.appendChild(ta);
        ta.select();
        try { document.execCommand('copy'); onCopied(); } catch (e) {}
        document.body.removeChild(ta);
      }

      function onCopied() {
        var label = document.getElementById('verifica-copy-text');
        copyBtn.classList.add('cf-copy--done');
        if (label) label.textContent = 'Copiato!';
        setTimeout(function () {
          copyBtn.classList.remove('cf-copy--done');
          if (label) label.textContent = 'Copia';
        }, 2000);
      }
    });
  }
})();
</script>
