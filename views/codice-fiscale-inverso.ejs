<section class="cf-page">
  <div class="cf-container cf-container--wide">
    <div class="cf-card">
      <div class="cf-card__header cf-card__header--inverso">
        <h1 class="cf-card__title">Codice Fiscale Inverso</h1>
        <p class="cf-card__subtitle">Inserisci un Codice Fiscale per decodificarne i dati anagrafici</p>
      </div>

      <div class="cf-card__body">
        <p class="error-msg" id="error-msg" hidden style="background:#fef2f2;border:1px solid #fecaca;color:#991b1b;padding:12px 16px;border-radius:8px;font-size:.875rem;margin-bottom:24px"></p>

        <div class="cf-field">
          <label class="cf-label" for="cf-input">Codice Fiscale</label>
          <input class="cf-input cf-input--mono" type="text" id="cf-input" name="codice_fiscale" placeholder="Es. RSSMRA85C15H501R" required maxlength="16" autocomplete="off" style="text-transform:uppercase;letter-spacing:.1em;font-family:'Courier New',monospace">
        </div>
        <div style="display:flex;gap:8px">
          <button type="button" class="cf-btn" id="decode-btn" style="flex:1">Decodifica Codice Fiscale</button>
          <button type="button" class="cf-btn" id="reset-btn" style="flex:0 0 auto;width:48px;background:var(--text-light);font-size:1.2rem" aria-label="Reset" title="Reset">↺</button>
        </div>

        <div class="result-section" role="status" aria-live="polite" id="result-section" hidden>
          <div class="cf-result">
            <span class="cf-result__label">Codice Fiscale Analizzato</span>
            <output class="cf-result__code" id="cf-output"></output>
            <button type="button" class="cf-copy" id="cf-copy-btn" aria-label="Copia Codice Fiscale negli appunti">
              <svg class="cf-copy__icon" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M8 2a1 1 0 000 2h2a1 1 0 100-2H8z"/><path d="M3 5a2 2 0 012-2 3 3 0 003 3h2a3 3 0 003-3 2 2 0 012 2v6h-4.586l1.293-1.293a1 1 0 00-1.414-1.414l-3 3a1 1 0 000 1.414l3 3a1 1 0 001.414-1.414L10.414 13H15v3a2 2 0 01-2 2H5a2 2 0 01-2-2V5z"/></svg>
              <span id="cf-copy-text">Copia</span>
            </button>
          </div>

          <div class="cf-breakdown">
            <h3>Scomposizione Visiva</h3>
            <div class="cf-chars" id="cf-chars"></div>
            <div class="cf-legend" id="cf-legend">
              <span class="legend-item legend-cognome">Cognome</span>
              <span class="legend-item legend-nome">Nome</span>
              <span class="legend-item legend-anno">Anno</span>
              <span class="legend-item legend-mese">Mese</span>
              <span class="legend-item legend-giorno">Giorno/Sesso</span>
              <span class="legend-item legend-comune">Comune</span>
              <span class="legend-item legend-controllo">Controllo</span>
            </div>
          </div>

          <div class="data-cards">
            <div class="data-card">
              <span class="data-card__icon">👤</span>
              <div class="data-card__label">Sesso</div>
              <div class="data-card__value" id="result-sesso"></div>
            </div>
            <div class="data-card">
              <span class="data-card__icon">📅</span>
              <div class="data-card__label">Data di Nascita</div>
              <div class="data-card__value" id="result-nascita"></div>
            </div>
            <div class="data-card">
              <span class="data-card__icon">📍</span>
              <div class="data-card__label">Codice Catastale</div>
              <div class="data-card__value" id="result-comune"></div>
            </div>
            <div class="data-card">
              <span class="data-card__icon">🎂</span>
              <div class="data-card__label">Età</div>
              <div class="data-card__value" id="result-eta"></div>
            </div>
          </div>

          <div class="detail-table-wrapper">
            <h3>Analisi Dettagliata dei Segmenti</h3>
            <table class="detail-table">
              <thead>
                <tr>
                  <th>Segmento</th>
                  <th>Caratteri</th>
                  <th>Valore</th>
                  <th>Descrizione</th>
                </tr>
              </thead>
              <tbody id="detail-tbody"></tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

