<nav class="breadcrumb" aria-label="Breadcrumb">
  <div class="container">
    <ol>
      <li><a href="/">Home</a></li>
      <li aria-current="page">Calcola Codice Fiscale</li>
    </ol>
  </div>
</nav>

<section class="hero">
  <div class="container">
    <div class="tool-card">
      <div class="tool-header">
        <h1>Calcola il tuo Codice Fiscale</h1>
        <p>Inserisci i tuoi dati anagrafici per generare il codice fiscale.</p>
      </div>
      <div class="tool-body">
        <% if (typeof errors !== 'undefined' && errors.length > 0) { %>
        <div class="error-box" role="alert">
          <ul>
            <% errors.forEach(function(err) { %>
            <li><%= err %></li>
            <% }); %>
          </ul>
        </div>
        <% } %>

        <% var fd = (typeof formData !== 'undefined' && formData) ? formData : { cognome: '', nome: '', sesso: '', data_nascita: '', comune: '' }; %>
        <form id="cf-form" method="POST" action="/tools/codice-fiscale-generator" novalidate>
          <div class="form-group">
            <label for="cognome">Cognome <span class="required">*</span></label>
            <input type="text" id="cognome" name="cognome" placeholder="Es. Rossi" required autocomplete="family-name" value="<%= fd.cognome %>">
          </div>
          <div class="form-group">
            <label for="nome">Nome <span class="required">*</span></label>
            <input type="text" id="nome" name="nome" placeholder="Es. Mario" required autocomplete="given-name" value="<%= fd.nome %>">
          </div>
          <div class="form-row">
            <div class="form-group">
              <label for="sesso">Sesso <span class="required">*</span></label>
              <select id="sesso" name="sesso" required>
                <option value="" disabled <%= fd.sesso === '' || !fd.sesso ? 'selected' : '' %>>Seleziona...</option>
                <option value="M" <%= fd.sesso === 'M' ? 'selected' : '' %>>M</option>
                <option value="F" <%= fd.sesso === 'F' ? 'selected' : '' %>>F</option>
              </select>
            </div>
            <div class="form-group">
              <label for="data_nascita">Data di Nascita <span class="required">*</span></label>
              <input type="date" id="data_nascita" name="data_nascita" required value="<%= fd.data_nascita %>">
            </div>
          </div>
          <div class="form-group comune-wrapper">
            <label for="comune">Comune di Nascita <span class="required">*</span></label>
            <input type="text" id="comune" name="comune" placeholder="Inizia a digitare il comune..." required autocomplete="off" value="<%= fd.comune %>">
            <div id="comune-list" class="autocomplete-list" style="display:none"></div>
            <div class="form-hint">Digita almeno 2 lettere per la ricerca</div>
          </div>
          <button type="submit" class="btn btn-primary"><span class="btn-text">Calcola Codice Fiscale</span><span class="spinner"></span></button>
        </form>

        <% var cfResult = (typeof result !== 'undefined') ? result : null; %>
        <div id="result-box" class="result-box" <% if (!cfResult) { %>style="display:none"<% } %>>
          <div class="result-label">Il tuo Codice Fiscale è:</div>
          <div id="result-code" class="result-code"><%= cfResult || '' %></div>
          <div class="result-actions">
            <button onclick="copyCF()" class="copy-btn"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg> Copia</button>
          </div>
        </div>

        <div class="tool-trust-row">
          <span class="tool-trust-item"><span class="tool-trust-icon trust-check">&#10003;</span> Calcolo preciso</span>
          <span class="tool-trust-item"><span class="tool-trust-icon trust-lock">&#128274;</span> Dati non salvati</span>
          <span class="tool-trust-item"><span class="tool-trust-icon trust-bolt">&#9889;</span> 100% gratuito</span>
        </div>

        <div class="disclaimer-box">
          <strong>Disclaimer:</strong> Questo strumento calcola il codice fiscale utilizzando l'algoritmo ufficiale. Il risultato potrebbe non coincidere con quello rilasciato dall'Agenzia delle Entrate in caso di omocodia. Per il codice fiscale ufficiale, rivolgiti all'Agenzia delle Entrate.
        </div>
      </div>
    </div>
  </div>
</section>

<section class="learn-more-section">
  <div class="container">
    <h2 class="learn-more-title">Scopri di più</h2>
    <div class="learn-more-pills">
      <a href="/guida/cose-il-codice-fiscale" class="learn-more-pill">Cos'è il Codice Fiscale?</a>
      <a href="/guida/come-si-calcola" class="learn-more-pill">Come si Calcola</a>
      <a href="/esempi-codice-fiscale" class="learn-more-pill">Esempi CF</a>
      <a href="/codice-fiscale-vs-partita-iva" class="learn-more-pill">CF vs Partita IVA</a>
      <a href="/recupero-codice-fiscale" class="learn-more-pill">Recupero CF</a>
    </div>
  </div>
</section>

<div id="toast" class="toast"></div>
